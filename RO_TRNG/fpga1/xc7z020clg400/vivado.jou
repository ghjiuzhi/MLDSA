open_project E:/Project/MLDSA/RO_TRNG/fpga1/xc7z020clg400/xc7z020clg400.xpr
update_compile_order -fileset sources_1
open_run impl_1
mark_objects -color red [get_cells -hierarchical -filter {NAME =~ *u_entropy_source/RO_NUM_LOOP[*].RO_AND.u_LUT6_and2_1/u_LUT6}]
